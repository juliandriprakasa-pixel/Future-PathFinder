<script>
// ── STATE ─────────────────────────────────────────────────────────
let userData={name:'Siswa',kelas:'8',guru:'—'};
let simScores={sma:0,smk:0};
let wsCount=0;
let menuOpen=false;

function updateUserUI(){
  const init=userData.name?userData.name[0].toUpperCase():'S';
  document.getElementById('navAvatar').textContent=init;
  document.getElementById('greetName').textContent='Halo, '+userData.name+'! 👋';
  document.getElementById('greetKelas').textContent=userData.kelas;
  document.getElementById('greetGuru').textContent=userData.guru;
  document.getElementById('profilAv').textContent=init;
  document.getElementById('profilName').textContent=userData.name;
  document.getElementById('profilSub').textContent='Kelas '+userData.kelas+' · Guru BK: '+userData.guru;
  document.getElementById('editNama').value=userData.name==='Siswa'?'':userData.name;
  document.getElementById('editKelas').value=userData.kelas==='8'?'':userData.kelas;
  document.getElementById('editGuru').value=userData.guru==='—'?'':userData.guru;
  if(document.getElementById('ws1-nama')&&userData.name!=='Siswa') document.getElementById('ws1-nama').value=userData.name;
  if(document.getElementById('ws1-kelas')&&userData.kelas!=='8') document.getElementById('ws1-kelas').value=userData.kelas;
}
function doLogout(){}
function saveProfile(){
  userData.name=document.getElementById('editNama').value.trim()||userData.name;
  userData.kelas=document.getElementById('editKelas').value.trim()||userData.kelas;
  userData.guru=document.getElementById('editGuru').value.trim()||userData.guru;
  updateUserUI();
  const s=document.getElementById('profil-saved');
  s.style.display='inline';setTimeout(()=>s.style.display='none',2500);
}

// ── NAV ───────────────────────────────────────────────────────────
const pages=['home','dashboard','program','simulasi','worksheet','konferensi','komitmen','profil'];
const progW=[12.5,25,37.5,50,62.5,75,87.5,100];
function toggleMenu(){menuOpen=!menuOpen;document.getElementById('mobileMenu').classList.toggle('open',menuOpen);document.getElementById('hamburger').classList.toggle('open',menuOpen);}
function closeMenu(){menuOpen=false;document.getElementById('mobileMenu').classList.remove('open');document.getElementById('hamburger').classList.remove('open');}
function goPage(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.mobile-nav-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  const i=pages.indexOf(id);
  if(i>=0){
    document.querySelectorAll('.nav-btn')[i].classList.add('active');
    document.querySelectorAll('.mobile-nav-btn')[i].classList.add('active');
    document.getElementById('progFill').style.width=progW[i]+'%';
  }
  if(id==='dashboard') updateDashboard();
  if(id==='konferensi') showConfStep(0);
  window.scrollTo({top:0,behavior:'smooth'});
}

// ── REMINDER ─────────────────────────────────────────────────────
function openReminder(){document.getElementById('reminderModal').classList.add('open');}
function closeReminder(){document.getElementById('reminderModal').classList.remove('open');}

// ── DASHBOARD ─────────────────────────────────────────────────────
function updateDashboard(){
  document.getElementById('dcWs').textContent=wsCount;
  document.getElementById('dcSim').textContent=simScores.sma+simScores.smk;
  document.getElementById('dcAch').textContent=wsCount>0?2:1;
  document.getElementById('psSim').textContent=simScores.sma+simScores.smk;
  document.getElementById('psWs').textContent=wsCount+'/4';
  document.getElementById('psAch').textContent=wsCount>0?2:1;
}

// ── EXPORT PDF ────────────────────────────────────────────────────
function exportPDF(){
  const name=userData.name||'Siswa';
  const lines=[];
  lines.push('=== FUTURE PATHFINDER — WORKSHEET EXPORT ===');
  lines.push('Nama: '+name+' | Kelas: '+userData.kelas+' | Guru BK: '+userData.guru);
  lines.push('Tanggal Export: '+new Date().toLocaleDateString('id-ID',{weekday:'long',year:'numeric',month:'long',day:'numeric'}));
  lines.push('');
  lines.push('--- WORKSHEET 1: WHO AM I? ---');
  lines.push('Pelajaran Favorit: '+(document.getElementById('ws1-mapel')?.value||'-'));
  lines.push('Hobi: '+(document.getElementById('ws1-hobi')?.value||'-'));
  lines.push('Cita-cita: '+(document.getElementById('ws1-cita')?.value||'-'));
  lines.push('Alasan: '+(document.getElementById('ws1-alasan')?.value||'-'));
  lines.push('');
  lines.push('--- WORKSHEET 2: SIMULATION LOG ---');
  document.querySelectorAll('#ws2 textarea').forEach((t,i)=>lines.push('Refleksi '+(i+1)+': '+(t.value||'-')));
  lines.push('');
  lines.push('--- WORKSHEET 3: REALITY CHECK ---');
  document.querySelectorAll('#ws3 textarea').forEach((t,i)=>lines.push('Jawaban '+(i+1)+': '+(t.value||'-')));
  lines.push('');
  lines.push('--- WORKSHEET 4: DECISION MAP ---');
  document.querySelectorAll('#ws4 textarea').forEach((t,i)=>lines.push('Jawaban '+(i+1)+': '+(t.value||'-')));
  lines.push('');
  lines.push('Skor Simulasi SMA: '+simScores.sma+' | SMK: '+simScores.smk);
  lines.push('=== END OF EXPORT ===');

  const blob=new Blob([lines.join('\n')],{type:'text/plain;charset=utf-8'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');
  a.href=url;a.download='FuturePathfinder_'+name.replace(/\s/g,'_')+'.txt';
  a.click();URL.revokeObjectURL(url);
}

// ── PROGRAM ───────────────────────────────────────────────────────
function toggleTl(card){
  const wasOpen=card.classList.contains('open');
  document.querySelectorAll('.tl-card').forEach(c=>c.classList.remove('open'));
  if(!wasOpen) card.classList.add('open');
}

// ── SIMULASI ─────────────────────────────────────────────────────
function switchSim(id,btn){
  document.querySelectorAll('.sim-tab').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.sim-content').forEach(c=>c.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('sim-'+id).classList.add('active');
}
function pickOpt(btn,path,idx){
  const opts=document.getElementById(path+'-opts').querySelectorAll('.scenario-opt');
  opts.forEach(o=>{o.classList.remove('chosen','wrong');o.disabled=true;});
  document.querySelectorAll('[id^="'+path+'-res-"]').forEach(r=>r.classList.remove('show'));
  const good=(idx===0);
  btn.classList.add(good?'chosen':'wrong');
  document.getElementById(path+'-res-'+idx).classList.add('show');
  if(good){
    simScores[path]+=10;
    document.getElementById(path+'-next').style.display='flex';
    const sc=document.getElementById(path+'-score');
    document.getElementById(path+'-score-num').textContent=simScores[path];
    sc.style.display='flex';
    updateDashboard();
  }
}

// ── WORKSHEET ────────────────────────────────────────────────────
function switchWs(id,btn){
  document.querySelectorAll('.ws-nav-btn').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.ws-page').forEach(p=>p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById(id).classList.add('active');
}
function setScale(btn,key){
  const row=btn.closest('.scale-row');
  row.querySelectorAll('.scale-btn').forEach(b=>b.classList.remove('sel'));
  btn.classList.add('sel');
  calcWs1();
}
function calcWs1(){
  const fields=['ws1-nama','ws1-mapel','ws1-hobi','ws1-cita','ws1-alasan'];
  let filled=0;
  fields.forEach(id=>{const el=document.getElementById(id);if(el&&el.value.trim())filled++;});
  const scales=['sc-praktik','sc-teori','sc-kerja'];
  scales.forEach(id=>{const el=document.getElementById(id);if(el&&el.querySelector('.sel'))filled++;});
  const total=fields.length+scales.length;
  const pct=Math.min(100,Math.round((filled/total)*100));
  document.getElementById('ws1-bar').style.width=pct+'%';
  document.getElementById('ws1-pct').textContent=pct+'%';
}
function calcWs2(){
  const inputs=document.querySelectorAll('#ws2 textarea');
  let filled=0;inputs.forEach(i=>{if(i.value.trim())filled++;});
  const pct=Math.round((filled/inputs.length)*100)||0;
  document.getElementById('ws2-bar').style.width=pct+'%';
  document.getElementById('ws2-pct').textContent=pct+'%';
}
function toggleCheck(el){
  el.classList.toggle('checked');
  el.querySelector('span').textContent=el.classList.contains('checked')?'✅':'☐';
}
function setCond(v){['sma','smk','ragu'].forEach(k=>document.getElementById('cond-'+k).classList.remove('chosen'));document.getElementById('cond-'+v).classList.add('chosen');}
function setDec(v){['sma','smk'].forEach(k=>document.getElementById('dec-'+k).classList.remove('chosen'));document.getElementById('dec-'+v).classList.add('chosen');}
function saveWs(id){
  wsCount=Math.min(4,wsCount+1);
  updateDashboard();
  // update skill bars
  const pcts=[Math.min(100,40+wsCount*15),Math.min(100,30+wsCount*12),Math.min(100,25+wsCount*10),Math.min(100,15+wsCount*10)];
  ['sk1','sk2','sk3','sk4'].forEach((k,i)=>{
    document.getElementById(k).style.width=pcts[i]+'%';
    document.getElementById(k+'v').textContent=pcts[i]+'%';
  });
  const saved=document.getElementById(id+'-saved');
  saved.style.display='inline';setTimeout(()=>saved.style.display='none',2500);
}

// ── KONFERENSI ───────────────────────────────────────────────────
const confData=[
  {title:'📝 Persiapan Konferensi',body:'Sebelum hari H, pastikan semua bahan sudah siap. Centang checklist berikut:',checks:['Worksheet 1–4 sudah selesai diisi','Sudah tahu pilihan sementara (SMA/SMK)','Sudah menyiapkan 3 alasan utama pilihanku','Sudah melatih presentasi minimal 1 kali','Orang tua / wali sudah tahu jadwal konferensi']},
  {title:'🎤 Presentasi oleh Siswa',body:'Kamu yang memimpin! Presentasikan refleksi perjalananmu kepada orang tua dan guru BK.',checks:['Perkenalkan dirimu & program Future Pathfinder','Ceritakan proses yang sudah kamu lalui (Fase 1–4)','Presentasikan pilihanmu & alasannya','Tunjukkan worksheet & future map-mu']},
  {title:'👂 Diskusi & Dialog',body:'Dengarkan orang tua dan guru BK. Ini diskusi dua arah, bukan debat.',checks:['Dengarkan respons orang tua dengan sabar','Tanggapi pertanyaan dengan tenang & jujur','Terbuka terhadap masukan','Guru BK memfasilitasi jika ada ketegangan']},
  {title:'🤝 Kesepakatan Bersama',body:'Capai kesepakatan tentang pilihan dan rencana ke depan.',checks:['Pilihan akhir sudah disepakati','Rencana dukungan orang tua didiskusikan','Tanda tangan ikrar komitmen bersama','Guru BK mendokumentasikan hasil']},
  {title:'📊 Evaluasi & Tindak Lanjut',body:'Guru BK merekap hasil dan merencanakan pendampingan lanjutan jika perlu.',checks:['Guru BK merekap data seluruh siswa','Siswa yang butuh pendampingan diidentifikasi','Konseling individual dijadwalkan jika perlu','Data diteruskan ke koordinator BK']}
];
const confChecks=[{},{},{},{},{}];
function showConfStep(i){
  document.querySelectorAll('.conf-step-box').forEach((b,j)=>b.classList.toggle('active',j===i));
  const d=confData[i];
  const ch=d.checks.map((c,ci)=>`<div class="conf-check ${confChecks[i][ci]?'done-check':''}" onclick="toggleConf(this,${i},${ci})"><div class="conf-check-icon">${confChecks[i][ci]?'✅':'☐'}</div> ${c}</div>`).join('');
  document.getElementById('conf-detail-area').innerHTML=`<div class="conf-detail"><h4>${d.title}</h4><p>${d.body}</p><div class="conf-checklist">${ch}</div></div>`;
}
function toggleConf(el,step,ci){confChecks[step][ci]=!confChecks[step][ci];showConfStep(step);}

// ── PLEDGE ────────────────────────────────────────────────────────
let pledgePath=null;
function setPledge(v){
  pledgePath=v;
  ['sma','smk'].forEach(k=>{document.getElementById('pchoice-'+k).classList.remove('picked','sma','smk');});
  document.getElementById('pchoice-'+v).classList.add('picked',v);
}
function generatePledge(){
  const name=document.getElementById('pledge-name').value.trim();
  if(!name){alert('Tulis namamu dulu ya! 😊');return;}
  if(!pledgePath){alert('Pilih jalurmu dulu ya! 😊');return;}
  const jalur=pledgePath==='sma'?'SMA/MA':'SMK/MAK';
  document.getElementById('pledge-text').textContent=`Saya, ${name}, dengan penuh kesadaran dan rasa syukur, berkomitmen untuk melanjutkan pendidikan ke jenjang ${jalur}. Saya telah melalui proses refleksi yang mendalam, mencoba berbagai simulasi, dan berdiskusi dengan orang-orang yang saya percaya. Ini adalah pilihanku, dan saya siap bertanggung jawab atas pilihan ini dengan sepenuh hati. Kelas 9, saya siap! 💪`;
  document.getElementById('pledge-date').textContent=new Date().toLocaleDateString('id-ID',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
  document.getElementById('pledge-stamp').classList.add('show');
}

// Init
showConfStep(0);
