<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Future Pathfinder</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=DM+Sans:wght@400;500;600;700&display=swap');
:root{
  --navy:#0f1b3c;--teal:#0d9488;--amber:#f59e0b;--coral:#f97316;--sky:#38bdf8;
  --purple:#8b5cf6;--pink:#ec4899;--green:#10b981;--red:#ef4444;
  --light:#f0fdf4;--cream:#fefce8;--text:#1e293b;--muted:#64748b;
  --bg:#f8fafc;--white:#fff;--border:#e2e8f0;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden;}



/* ===== NAV ===== */
.nav-bar{background:var(--navy);padding:0 16px;display:flex;align-items:center;justify-content:space-between;height:56px;position:sticky;top:0;z-index:200;box-shadow:0 2px 12px rgba(0,0,0,.2);}
.nav-logo{font-family:'Sora',sans-serif;color:#fff;font-weight:800;font-size:17px;cursor:pointer;}
.nav-logo span{color:var(--amber);}
.nav-links{display:flex;gap:2px;}
.nav-btn{background:none;border:none;color:rgba(255,255,255,.7);font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;padding:7px 10px;border-radius:8px;cursor:pointer;transition:all .2s;white-space:nowrap;}
.nav-btn:hover{color:#fff;background:rgba(255,255,255,.08);}
.nav-btn.active{color:var(--amber);background:rgba(245,158,11,.15);}
.nav-right{display:flex;align-items:center;gap:10px;}
.nav-avatar{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--teal),var(--sky));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;color:#fff;cursor:pointer;border:2px solid rgba(255,255,255,.2);flex-shrink:0;}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:4px;}
.hamburger span{display:block;width:22px;height:2px;background:#fff;border-radius:2px;transition:all .3s;}
.hamburger.open span:nth-child(1){transform:rotate(45deg) translate(5px,5px);}
.hamburger.open span:nth-child(2){opacity:0;}
.hamburger.open span:nth-child(3){transform:rotate(-45deg) translate(5px,-5px);}
.mobile-menu{display:none;position:fixed;top:56px;left:0;right:0;background:var(--navy);z-index:190;flex-direction:column;padding:8px 16px 16px;border-top:1px solid rgba(255,255,255,.1);box-shadow:0 8px 24px rgba(0,0,0,.3);}
.mobile-menu.open{display:flex;}
.mobile-nav-btn{background:none;border:none;color:rgba(255,255,255,.8);font-family:'DM Sans',sans-serif;font-size:15px;font-weight:500;padding:13px 8px;text-align:left;border-bottom:1px solid rgba(255,255,255,.07);cursor:pointer;}
.mobile-nav-btn:last-child{border-bottom:none;}
.mobile-nav-btn.active{color:var(--amber);}
.progress-bar{height:4px;background:rgba(0,0,0,.1);}
.progress-fill{height:100%;background:linear-gradient(90deg,var(--purple),var(--pink),var(--amber));transition:width .5s ease;border-radius:2px;}

/* ===== PAGES ===== */
.page{display:none;animation:fadeUp .35s ease;}
.page.active{display:block;}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);}}

/* ===== SHARED COMPONENTS ===== */
.section{padding:32px 16px;}
.section-alt{background:linear-gradient(180deg,#f0fdf4 0%,#fefce8 100%);}
.sec-tag{font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;margin-bottom:6px;display:inline-block;padding:3px 10px;border-radius:20px;}
.sec-title{font-family:'Sora',sans-serif;font-size:22px;font-weight:800;color:var(--navy);line-height:1.2;}
.sec-sub{color:var(--muted);font-size:13px;margin-top:6px;line-height:1.6;}
.sec-hd{margin-bottom:24px;}
.card{background:#fff;border-radius:16px;padding:18px;border:1px solid var(--border);transition:transform .2s,box-shadow .2s;}
.card:hover{transform:translateY(-4px);box-shadow:0 12px 32px rgba(0,0,0,.1);}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.grid3{display:grid;grid-template-columns:1fr;gap:12px;}
.btn-primary{background:linear-gradient(90deg,var(--amber),var(--coral));color:var(--navy);padding:12px 22px;border-radius:12px;font-weight:700;font-size:14px;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;transition:transform .2s,box-shadow .2s;}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(245,158,11,.4);}
.btn-teal{background:linear-gradient(90deg,var(--teal),var(--green));color:#fff;padding:12px 22px;border-radius:12px;font-weight:700;font-size:14px;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;transition:transform .2s,box-shadow .2s;}
.btn-teal:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(13,148,136,.35);}
.chip{padding:4px 12px;border-radius:20px;font-size:11px;font-weight:600;}
.chip-ak{background:#dbeafe;color:#1e40af;}
.chip-kar{background:#dcfce7;color:#166534;}
.chip-pri{background:#fce7f3;color:#9d174d;}
.chip-sos{background:#fef3c7;color:#92400e;}
.info-note{background:var(--cream);border-left:4px solid var(--amber);padding:12px 14px;border-radius:0 10px 10px 0;font-size:12px;color:#78350f;margin-top:14px;line-height:1.5;}
.badge-dot{display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:4px;}

/* ===== HERO ===== */
.hero{background:linear-gradient(135deg,#0f1b3c 0%,#1e3a5f 45%,#0d4d4d 100%);padding:36px 16px 32px;position:relative;overflow:hidden;}
.hero::before,.hero::after{content:'';position:absolute;border-radius:50%;pointer-events:none;}
.hero::before{width:250px;height:250px;background:radial-gradient(circle,rgba(245,158,11,.2),transparent 70%);top:-80px;right:-60px;}
.hero::after{width:180px;height:180px;background:radial-gradient(circle,rgba(56,189,248,.15),transparent 70%);bottom:-60px;left:-40px;}
.hero-tag{background:rgba(245,158,11,.2);color:var(--amber);padding:5px 14px;border-radius:20px;font-size:11px;font-weight:700;letter-spacing:1px;display:inline-block;margin-bottom:14px;}
.hero h1{font-family:'Sora',sans-serif;font-size:26px;font-weight:800;color:#fff;line-height:1.2;margin-bottom:12px;}
.hero h1 .h-amber{color:var(--amber);}
.hero h1 .h-sky{color:var(--sky);}
.hero p{color:rgba(255,255,255,.75);font-size:13px;line-height:1.7;margin-bottom:20px;}
.hero-btns{display:flex;gap:10px;flex-wrap:wrap;}
.btn-outline{border:2px solid rgba(255,255,255,.4);color:#fff;padding:12px 20px;border-radius:12px;font-weight:600;font-size:13px;background:none;cursor:pointer;font-family:'DM Sans',sans-serif;}
.hero-stats{display:flex;gap:10px;margin-top:20px;}
.hero-stat{background:rgba(255,255,255,.1);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.15);border-radius:12px;padding:12px 14px;flex:1;text-align:center;}
.hero-stat .num{font-family:'Sora',sans-serif;font-size:22px;font-weight:800;}
.hero-stat .lbl{color:rgba(255,255,255,.65);font-size:10px;margin-top:2px;}
.hs1 .num{color:var(--amber);}
.hs2 .num{color:var(--sky);}
.hs3 .num{color:var(--green);}

/* ===== HOME FEATURE CARDS ===== */
.feat-card{border-radius:18px;padding:20px;cursor:pointer;position:relative;overflow:hidden;transition:transform .2s,box-shadow .2s;}
.feat-card:hover{transform:translateY(-5px);box-shadow:0 16px 40px rgba(0,0,0,.15);}
.fc1{background:linear-gradient(135deg,#0f1b3c,#1e3a5f);}
.fc2{background:linear-gradient(135deg,#0d4d4d,var(--teal));}
.fc3{background:linear-gradient(135deg,#92400e,var(--amber));}
.fc4{background:linear-gradient(135deg,#5b21b6,var(--purple));}
.fc5{background:linear-gradient(135deg,#be185d,var(--pink));}
.fc6{background:linear-gradient(135deg,#065f46,var(--green));}
.feat-card h3{font-family:'Sora',sans-serif;color:#fff;font-size:16px;font-weight:700;margin-bottom:5px;}
.feat-card p{color:rgba(255,255,255,.7);font-size:12px;line-height:1.5;}
.feat-card .fc-icon{font-size:32px;margin-bottom:10px;}
.feat-card .fc-arrow{position:absolute;bottom:16px;right:16px;color:rgba(255,255,255,.5);font-size:18px;}
.feat-card .fc-badge{display:inline-block;background:rgba(255,255,255,.2);color:#fff;padding:3px 10px;border-radius:20px;font-size:10px;font-weight:700;margin-bottom:8px;}

/* ===== DASHBOARD ===== */
.dash-greeting{background:linear-gradient(135deg,var(--navy),#1e3a5f);border-radius:18px;padding:20px;color:#fff;margin-bottom:16px;position:relative;overflow:hidden;}
.dash-greeting::after{content:'🎯';position:absolute;right:16px;top:50%;transform:translateY(-50%);font-size:48px;opacity:.15;}
.dash-greeting h2{font-family:'Sora',sans-serif;font-size:20px;font-weight:800;margin-bottom:4px;}
.dash-greeting p{color:rgba(255,255,255,.7);font-size:13px;}
.dash-greeting .dg-tag{background:rgba(245,158,11,.25);color:var(--amber);padding:3px 10px;border-radius:20px;font-size:10px;font-weight:700;display:inline-block;margin-bottom:8px;}
.progress-ring-wrap{display:flex;align-items:center;gap:16px;margin-top:16px;}
.ring-outer{width:70px;height:70px;flex-shrink:0;}
.ring-svg{width:70px;height:70px;transform:rotate(-90deg);}
.ring-bg{fill:none;stroke:rgba(255,255,255,.15);stroke-width:6;}
.ring-fill{fill:none;stroke:var(--amber);stroke-width:6;stroke-linecap:round;transition:stroke-dashoffset .8s ease;}
.ring-label{position:relative;width:70px;height:70px;margin-top:-70px;display:flex;align-items:center;justify-content:center;flex-direction:column;}
.ring-label span{font-family:'Sora',sans-serif;font-size:16px;font-weight:800;color:#fff;}
.ring-label small{font-size:9px;color:rgba(255,255,255,.6);}
.ring-info{flex:1;}
.ring-info h4{font-family:'Sora',sans-serif;font-size:15px;font-weight:700;color:#fff;}
.ring-info p{font-size:12px;color:rgba(255,255,255,.65);margin-top:4px;line-height:1.5;}
.dash-cards{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px;}
.dc{background:#fff;border-radius:14px;padding:14px;border:1px solid var(--border);text-align:center;}
.dc .dc-num{font-family:'Sora',sans-serif;font-size:24px;font-weight:800;}
.dc .dc-lbl{font-size:11px;color:var(--muted);margin-top:2px;}
.dc1 .dc-num{color:var(--teal);}
.dc2 .dc-num{color:var(--purple);}
.dc3 .dc-num{color:var(--amber);}
.dc4 .dc-num{color:var(--pink);}
.activity-feed{background:#fff;border-radius:16px;padding:16px;border:1px solid var(--border);}
.af-title{font-family:'Sora',sans-serif;font-size:14px;font-weight:700;color:var(--navy);margin-bottom:12px;}
.af-item{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid #f1f5f9;}
.af-item:last-child{border-bottom:none;padding-bottom:0;}
.af-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;}
.af-text{flex:1;}
.af-text strong{font-size:13px;color:var(--navy);}
.af-text span{display:block;font-size:11px;color:var(--muted);margin-top:1px;}
.af-time{font-size:11px;color:var(--muted);white-space:nowrap;}
.notif-badge{background:var(--red);color:#fff;border-radius:50%;width:18px;height:18px;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;position:absolute;top:-4px;right:-4px;}

/* ===== TIMELINE ===== */
.timeline{position:relative;padding-left:30px;}
.timeline::before{content:'';position:absolute;left:9px;top:0;bottom:0;width:2px;background:linear-gradient(to bottom,var(--sky),var(--teal),var(--amber),var(--coral),var(--purple),var(--green));}
.tl-item{position:relative;margin-bottom:14px;}
.tl-dot{position:absolute;left:-25px;top:13px;width:14px;height:14px;border-radius:50%;border:3px solid #fff;box-shadow:0 0 0 2px currentColor;}
.tl-dot.d1{color:var(--sky);background:var(--sky);}
.tl-dot.d2{color:var(--teal);background:var(--teal);}
.tl-dot.d3{color:var(--amber);background:var(--amber);}
.tl-dot.d4{color:var(--coral);background:var(--coral);}
.tl-dot.d5{color:var(--purple);background:var(--purple);}
.tl-dot.d6{color:var(--green);background:var(--green);}
.tl-card{background:#fff;border-radius:14px;padding:14px 16px;border:1px solid var(--border);cursor:pointer;transition:box-shadow .2s;}
.tl-card.open{box-shadow:0 6px 24px rgba(0,0,0,.1);}
.tl-header{display:flex;justify-content:space-between;align-items:center;gap:8px;}
.tl-phase{font-size:10px;font-weight:700;letter-spacing:1.5px;color:var(--muted);text-transform:uppercase;}
.tl-name{font-family:'Sora',sans-serif;font-size:14px;font-weight:700;color:var(--navy);margin-top:3px;}
.tl-arrow{font-size:14px;color:var(--muted);transition:transform .3s;flex-shrink:0;}
.tl-card.open .tl-arrow{transform:rotate(180deg);}
.tl-body{display:none;margin-top:12px;padding-top:12px;border-top:1px solid #f1f5f9;font-size:12px;color:#475569;line-height:1.7;}
.tl-card.open .tl-body{display:block;}
.tl-tags{display:flex;gap:5px;margin-top:8px;flex-wrap:wrap;}
.tag-pill{padding:3px 9px;border-radius:20px;font-size:10px;font-weight:700;}

/* ===== SIMULASI ===== */
.sim-tabs{display:flex;background:#f1f5f9;border-radius:14px;padding:4px;margin-bottom:16px;}
.sim-tab{flex:1;background:none;border:none;padding:10px;border-radius:11px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:13px;color:var(--muted);cursor:pointer;transition:all .2s;}
.sim-tab.active{background:#fff;color:var(--navy);box-shadow:0 2px 8px rgba(0,0,0,.1);}
.sim-content{display:none;}
.sim-content.active{display:block;animation:fadeUp .3s ease;}
.sim-box{border-radius:16px;padding:20px;color:#fff;position:relative;overflow:hidden;}
.sim-box::after{content:'';position:absolute;bottom:-30px;right:-30px;width:120px;height:120px;border-radius:50%;background:rgba(255,255,255,.07);}
.sb-sma{background:linear-gradient(135deg,var(--navy),#1e3a5f);}
.sb-smk{background:linear-gradient(135deg,#0d4d4d,var(--teal));}
.sim-box h3{font-family:'Sora',sans-serif;font-size:20px;font-weight:800;margin-bottom:4px;}
.sim-tagline{color:rgba(255,255,255,.65);font-size:12px;margin-bottom:14px;}
.sim-badge{display:inline-block;background:var(--amber);color:var(--navy);padding:3px 12px;border-radius:20px;font-size:10px;font-weight:700;margin-bottom:10px;}
.sim-activity{background:rgba(255,255,255,.12);border-radius:10px;padding:9px 12px;margin-bottom:6px;font-size:13px;display:flex;align-items:center;gap:8px;}
.sim-scenario{background:#fff;border-radius:16px;padding:18px;margin-top:14px;border:2px solid var(--amber);}
.sim-scenario h4{font-family:'Sora',sans-serif;font-size:14px;font-weight:700;color:var(--navy);margin-bottom:8px;}
.scenario-opts{display:flex;flex-direction:column;gap:8px;margin-top:8px;}
.scenario-opt{background:#f8fafc;border:2px solid var(--border);border-radius:10px;padding:10px 12px;cursor:pointer;font-size:13px;font-weight:500;color:var(--text);transition:all .2s;text-align:left;font-family:'DM Sans',sans-serif;line-height:1.4;}
.scenario-opt:hover{border-color:var(--teal);background:var(--light);}
.scenario-opt.chosen{border-color:var(--teal);background:var(--light);color:var(--teal);}
.scenario-opt.wrong{border-color:var(--red);background:#fef2f2;color:var(--red);}
.scenario-opt:disabled{cursor:default;}
.scenario-result{margin-top:10px;padding:11px 14px;border-radius:10px;font-size:13px;font-weight:500;display:none;line-height:1.5;}
.scenario-result.show{display:block;}
.scenario-result.good{background:#dcfce7;color:#166534;}
.scenario-result.bad{background:#fef2f2;color:#dc2626;}
.scenario-next{margin-top:10px;display:none;}
.scenario-next.show{display:flex;}
.sim-score{background:linear-gradient(135deg,var(--purple),var(--pink));border-radius:14px;padding:16px;color:#fff;margin-top:14px;display:flex;align-items:center;gap:14px;}
.sim-score-num{font-family:'Sora',sans-serif;font-size:36px;font-weight:800;}
.sim-score-info h4{font-weight:700;font-size:14px;}
.sim-score-info p{font-size:12px;opacity:.8;margin-top:2px;}

/* ===== WORKSHEET ===== */
.ws-nav{display:flex;gap:6px;overflow-x:auto;padding-bottom:4px;margin-bottom:18px;-webkit-overflow-scrolling:touch;}
.ws-nav::-webkit-scrollbar{height:3px;}
.ws-nav::-webkit-scrollbar-thumb{background:var(--teal);border-radius:3px;}
.ws-nav-btn{background:#fff;border:2px solid var(--border);border-radius:10px;padding:7px 13px;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;cursor:pointer;color:var(--muted);transition:all .2s;white-space:nowrap;flex-shrink:0;}
.ws-nav-btn.active{border-color:var(--teal);color:var(--teal);background:var(--light);}
.ws-page{display:none;}
.ws-page.active{display:block;animation:fadeUp .3s ease;}
.ws-card{background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,.07);}
.ws-head{padding:16px 20px;}
.ws-head h3{font-family:'Sora',sans-serif;color:#fff;font-size:14px;font-weight:700;}
.ws-head p{color:rgba(255,255,255,.6);font-size:11px;margin-top:3px;}
.ws-body{padding:18px;}
.ws-field{margin-bottom:13px;}
.ws-label{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:5px;}
.ws-input{border:1.5px solid var(--border);border-radius:9px;padding:10px 12px;font-size:14px;color:var(--text);width:100%;background:#f8fafc;font-family:'DM Sans',sans-serif;transition:border .2s,background .2s;}
.ws-input:focus{outline:none;border-color:var(--teal);background:#fff;}
textarea.ws-input{resize:vertical;min-height:60px;}
.ws-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.ws-section{font-family:'Sora',sans-serif;font-size:12px;font-weight:700;color:var(--navy);margin:14px 0 9px;padding-bottom:6px;border-bottom:2px solid var(--teal);}
.scale-row{display:flex;gap:6px;}
.scale-btn{flex:1;height:38px;border-radius:8px;border:1.5px solid var(--border);background:#fff;font-size:13px;font-weight:600;color:var(--muted);cursor:pointer;transition:all .2s;}
.scale-btn.sel{background:var(--teal);border-color:var(--teal);color:#fff;transform:scale(1.08);}
.scale-label{font-size:10px;color:var(--muted);margin-top:4px;display:flex;justify-content:space-between;}
.check-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px;}
.check-item{display:flex;align-items:center;gap:6px;padding:9px 10px;border:1.5px solid var(--border);border-radius:9px;cursor:pointer;font-size:12px;transition:all .2s;background:#f8fafc;line-height:1.3;}
.check-item.checked{border-color:var(--teal);background:var(--light);color:var(--teal);font-weight:600;}
.ws-save{background:linear-gradient(90deg,var(--teal),var(--green));color:#fff;border:none;padding:11px 22px;border-radius:11px;font-family:'DM Sans',sans-serif;font-weight:700;font-size:14px;cursor:pointer;transition:transform .2s,box-shadow .2s;}
.ws-save:hover{transform:translateY(-2px);box-shadow:0 5px 16px rgba(13,148,136,.35);}
.ws-saved{display:none;margin-left:10px;color:var(--teal);font-weight:600;font-size:13px;vertical-align:middle;}
.ws-progress{height:6px;background:#e2e8f0;border-radius:3px;margin-bottom:14px;overflow:hidden;}
.ws-progress-fill{height:100%;background:linear-gradient(90deg,var(--teal),var(--sky));border-radius:3px;transition:width .5s;}
.ws-prog-text{font-size:11px;color:var(--muted);margin-bottom:4px;display:flex;justify-content:space-between;}

/* ===== KONFERENSI ===== */
.conf-steps{display:flex;overflow-x:auto;gap:8px;padding-bottom:8px;-webkit-overflow-scrolling:touch;}
.conf-steps::-webkit-scrollbar{height:3px;}
.conf-steps::-webkit-scrollbar-thumb{background:var(--teal);border-radius:3px;}
.conf-step-box{background:#fff;border:2px solid var(--border);border-radius:14px;padding:14px 10px;min-width:100px;text-align:center;flex-shrink:0;cursor:pointer;transition:all .2s;}
.conf-step-box.active{border-color:var(--teal);box-shadow:0 4px 14px rgba(13,148,136,.2);}
.conf-step-box.done{border-color:var(--green);background:#f0fdf4;}
.conf-step-icon{font-size:22px;margin-bottom:5px;}
.conf-step-title{font-family:'Sora',sans-serif;font-size:11px;font-weight:700;color:var(--navy);}
.conf-step-desc{font-size:10px;color:var(--muted);margin-top:2px;}
